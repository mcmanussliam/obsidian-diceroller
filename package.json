{
  "name": "obsidian-diceroller",
  "version": "1.2.1",
  "description": "Dice Roller overlay plugin for Obsidian",
  "main": "main.js",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "lint": "eslint . && tsc --noEmit",
    "format": "prettier --write ./src",
    "format:check": "prettier --check ./src",
    "changelog": "./scripts/changelog.js",
    "version": "./scripts/version-bump.js && git add ."
  },
  "dependencies": {
    "cannon-es": "0.9.1",
    "rpg-dice-roller": "5.0.0",
    "three": "0.162.0"
  },
  "devDependencies": {
    "@eslint/js": "9.30.1",
    "@types/node": "20.9.5",
    "@types/three": "0.162.0",
    "eslint": "9.30.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-obsidianmd": "0.1.9",
    "globals": "14.0.0",
    "obsidian": "1.8.7",
    "prettier": "3.8.3",
    "typescript": "5.4.5",
    "typescript-eslint": "8.35.1",
    "vite": "5.4.9"
  }
}
